generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Multi-tenancy ──────────────────────────────────────────

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logoUrl   String?
  brandColor String  @default("#6366f1")
  domain    String?  @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users         User[]
  skills        Skill[]
  connections   Connection[]
  libraryItems  LibraryItem[]
  invitations   Invitation[]
  notifications Notification[]
  subscription  Subscription?
}

// ─── Auth (NextAuth v5 + custom fields) ─────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Users ──────────────────────────────────────────────────

enum Role {
  MENTOR
  MENTEE
  ADMIN
}

enum UserStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  name          String?
  password      String?
  emailVerified DateTime?
  image         String?
  role          Role?
  status        UserStatus @default(PENDING)
  bio           String?    @db.Text
  headline      String?
  education     String?    @db.Text
  experience    String?    @db.Text
  linkedin      String?
  whatsapp      String?
  maxMentees    Int        @default(4)
  tenantId      String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  tenant        Tenant?       @relation(fields: [tenantId], references: [id])
  accounts      Account[]
  sessions      Session[]
  skills        UserSkill[]
  mentorConns   Connection[]  @relation("MentorConnections")
  menteeConns   Connection[]  @relation("MenteeConnections")
  waitlistAsMentee WaitlistEntry[] @relation("WaitlistMentee")
  waitlistAsMentor WaitlistEntry[] @relation("WaitlistMentor")
  notifications Notification[]
  libraryItems  LibraryItem[] @relation("UploadedBy")

  @@index([tenantId])
  @@index([role])
  @@index([status])
}

// ─── Skills ─────────────────────────────────────────────────

model Skill {
  id        String   @id @default(cuid())
  name      String
  tenantId  String?
  global    Boolean  @default(false)
  createdAt DateTime @default(now())

  tenant    Tenant?     @relation(fields: [tenantId], references: [id])
  users     UserSkill[]

  @@unique([name, tenantId])
  @@index([tenantId])
}

enum SkillType {
  TEACHING
  LEARNING
}

model UserSkill {
  id      String    @id @default(cuid())
  userId  String
  skillId String
  type    SkillType

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([userId, skillId, type])
}

// ─── Connections (Mentoring relationships) ──────────────────

enum ConnectionStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
  COMPLETED
}

model Connection {
  id        String           @id @default(cuid())
  mentorId  String
  menteeId  String
  tenantId  String
  status    ConnectionStatus @default(PENDING)
  message   String?          @db.Text
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  mentor User @relation("MentorConnections", fields: [mentorId], references: [id])
  mentee User        @relation("MenteeConnections", fields: [menteeId], references: [id])
  tenant Tenant      @relation(fields: [tenantId], references: [id])

  @@index([mentorId])
  @@index([menteeId])
  @@index([tenantId])
}

// ─── Waitlist ───────────────────────────────────────────────

model WaitlistEntry {
  id        String   @id @default(cuid())
  mentorId  String
  menteeId  String
  position  Int
  createdAt DateTime @default(now())

  mentor User @relation("WaitlistMentor", fields: [mentorId], references: [id])
  mentee User @relation("WaitlistMentee", fields: [menteeId], references: [id])

  @@unique([mentorId, menteeId])
  @@index([mentorId])
}

// ─── Library ────────────────────────────────────────────────

enum FileType {
  PDF
  VIDEO
  ARTICLE
  OTHER
}

model LibraryItem {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  fileUrl     String
  fileType    FileType @default(PDF)
  fileSize    Int?
  tenantId    String
  uploadedById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant     Tenant @relation(fields: [tenantId], references: [id])
  uploadedBy User   @relation("UploadedBy", fields: [uploadedById], references: [id])

  @@index([tenantId])
}

// ─── Invitations ────────────────────────────────────────────

model Invitation {
  id        String   @id @default(cuid())
  email     String
  tenantId  String
  role      Role
  token     String   @unique @default(cuid())
  used      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([token])
}

// ─── Notifications ──────────────────────────────────────────

enum NotificationType {
  CONNECTION_REQUEST
  CONNECTION_ACCEPTED
  CONNECTION_REJECTED
  WAITLIST_PROMOTED
  NEW_MATERIAL
  ACCOUNT_APPROVED
  SYSTEM
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  tenantId  String
  type      NotificationType
  title     String
  message   String           @db.Text
  read      Boolean          @default(false)
  metadata  Json?
  createdAt DateTime         @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([userId, read])
  @@index([tenantId])
}

// ─── Billing ────────────────────────────────────────────────

enum PlanTier {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

model Plan {
  id            String   @id @default(cuid())
  name          String
  tier          PlanTier @unique
  price         Int      @default(0)
  maxUsers      Int      @default(50)
  maxMentors    Int      @default(10)
  maxLibraryMb  Int      @default(500)
  features      Json?
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())

  subscriptions Subscription[]
}

model Subscription {
  id        String   @id @default(cuid())
  tenantId  String   @unique
  planId    String
  active    Boolean  @default(true)
  startDate DateTime @default(now())
  endDate   DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  plan    Plan    @relation(fields: [planId], references: [id])
  invoices Invoice[]
}

model Invoice {
  id             String   @id @default(cuid())
  subscriptionId String
  amount         Int
  currency       String   @default("BRL")
  status         String   @default("paid")
  paidAt         DateTime?
  createdAt      DateTime @default(now())

  subscription Subscription @relation(fields: [subscriptionId], references: [id])
}

model Usage {
  id        String   @id @default(cuid())
  tenantId  String
  metric    String
  value     Int
  period    String
  createdAt DateTime @default(now())

  @@unique([tenantId, metric, period])
}
