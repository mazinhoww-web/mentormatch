generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Multi-tenancy ──────────────────────────────────────────

model Tenant {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  logoUrl        String?
  brandColor     String   @default("#6366f1")
  secondaryColor String?
  domain         String?  @unique
  active         Boolean  @default(true)

  // Theme system
  themeKey       String   @default("dark")
  themeCssUrl    String?
  tokens         String?  @db.Text

  // Limits
  maxUsers       Int      @default(50)
  maxConnections Int      @default(100)
  maxLibraryItems Int     @default(10)

  // Plan relation
  planId         String?
  plan           Plan?    @relation(fields: [planId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users         User[]
  connections   Connection[]
  libraryItems  LibraryItem[]
  invitations   Invitation[]
  notifications Notification[]
  subscription  Subscription?

  @@map("mm_tenant")
}

// ─── Auth (NextAuth v5 + custom fields) ─────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("mm_account")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("mm_session")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("mm_verification_token")
}

// ─── Users ──────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  ADMIN
  MENTOR
  MENTEE
}

enum UserStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

model User {
  id            String     @id @default(cuid())
  email         String
  name          String?
  password      String?
  emailVerified DateTime?
  image         String?
  role          Role?
  status        UserStatus @default(PENDING)
  bio           String?    @db.Text
  headline      String?
  position      String?
  department    String?
  languages     String[]
  type          String?
  education     String?    @db.Text
  experience    String?    @db.Text
  linkedin      String?
  whatsapp      String?
  maxMentees    Int        @default(4)
  tenantId      String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  tenant        Tenant?       @relation(fields: [tenantId], references: [id])
  accounts      Account[]
  sessions      Session[]
  skills        UserSkill[]
  mentorConns   Connection[]  @relation("MentorConnections")
  menteeConns   Connection[]  @relation("MenteeConnections")
  waitlistAsMentee WaitlistEntry[] @relation("WaitlistMentee")
  waitlistAsMentor WaitlistEntry[] @relation("WaitlistMentor")
  notifications Notification[]
  libraryItems  LibraryItem[] @relation("UploadedBy")
  invitationsSent Invitation[] @relation("InvitedBy")

  @@unique([email, tenantId])
  @@index([tenantId])
  @@index([role, tenantId])
  @@index([status, tenantId])
  @@map("mm_user")
}

// ─── Skills ─────────────────────────────────────────────────

model Skill {
  id         String   @id @default(cuid())
  name       String   @unique
  category   String?
  usageCount Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  users UserSkill[]

  @@index([usageCount])
  @@index([category])
  @@map("mm_skill")
}

model UserSkill {
  id         String  @id @default(cuid())
  userId     String
  skillId    String
  isTeaching Boolean @default(false)

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([userId, skillId])
  @@map("mm_user_skill")
}

// ─── Connections (Mentoring relationships) ──────────────────

enum ConnectionStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
  COMPLETED
}

model Connection {
  id        String           @id @default(cuid())
  mentorId  String
  menteeId  String
  tenantId  String
  status    ConnectionStatus @default(PENDING)
  message   String?          @db.Text
  startedAt DateTime?
  endedAt   DateTime?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  mentor User   @relation("MentorConnections", fields: [mentorId], references: [id])
  mentee User   @relation("MenteeConnections", fields: [menteeId], references: [id])
  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([mentorId, menteeId, status])
  @@index([mentorId, status])
  @@index([menteeId])
  @@index([tenantId])
  @@map("mm_connection")
}

// ─── Waitlist ───────────────────────────────────────────────

model WaitlistEntry {
  id        String   @id @default(cuid())
  mentorId  String
  menteeId  String
  position  Int
  createdAt DateTime @default(now())

  mentor User @relation("WaitlistMentor", fields: [mentorId], references: [id])
  mentee User @relation("WaitlistMentee", fields: [menteeId], references: [id])

  @@unique([mentorId, menteeId])
  @@index([mentorId, position])
  @@map("mm_waitlist_entry")
}

// ─── Library ────────────────────────────────────────────────

enum FileType {
  PDF
  VIDEO
  ARTICLE
  OTHER
}

model LibraryItem {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  fileUrl     String
  fileType    FileType @default(PDF)
  fileSize    Int?
  tenantId    String
  uploadedById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant     Tenant @relation(fields: [tenantId], references: [id])
  uploadedBy User   @relation("UploadedBy", fields: [uploadedById], references: [id])

  @@index([tenantId])
  @@map("mm_library_item")
}

// ─── Invitations ────────────────────────────────────────────

model Invitation {
  id          String   @id @default(cuid())
  email       String
  tenantId    String
  role        Role
  token       String   @unique @default(cuid())
  used        Boolean  @default(false)
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  // Who sent the invitation
  invitedById String?
  invitedBy   User?    @relation("InvitedBy", fields: [invitedById], references: [id])
  type        String?

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([token])
  @@map("mm_invitation")
}

// ─── Notifications ──────────────────────────────────────────

enum NotificationType {
  CONNECTION_REQUEST
  CONNECTION_ACCEPTED
  CONNECTION_REJECTED
  WAITLIST_PROMOTED
  NEW_MATERIAL
  ACCOUNT_APPROVED
  SYSTEM
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  tenantId  String
  type      NotificationType
  title     String
  message   String           @db.Text
  read      Boolean          @default(false)
  metadata  Json?
  createdAt DateTime         @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([userId, read])
  @@index([tenantId])
  @@map("mm_notification")
}

// ─── Billing ────────────────────────────────────────────────

model Plan {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  description    String?
  priceMonthly   Int      @default(0)
  priceYearly    Int      @default(0)
  maxUsers       Int      @default(50)
  maxConnections Int      @default(100)
  maxLibraryItems Int     @default(10)
  maxAdmins      Int      @default(1)
  features       Json?
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())

  tenants       Tenant[]
  subscriptions Subscription[]

  @@map("mm_plan")
}

model Subscription {
  id        String   @id @default(cuid())
  tenantId  String   @unique
  planId    String
  active    Boolean  @default(true)
  startDate DateTime @default(now())
  endDate   DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  plan    Plan    @relation(fields: [planId], references: [id])
  invoices Invoice[]

  @@map("mm_subscription")
}

model Invoice {
  id             String   @id @default(cuid())
  subscriptionId String
  amount         Int
  currency       String   @default("BRL")
  status         String   @default("paid")
  paidAt         DateTime?
  createdAt      DateTime @default(now())

  subscription Subscription @relation(fields: [subscriptionId], references: [id])

  @@map("mm_invoice")
}

model Usage {
  id        String   @id @default(cuid())
  tenantId  String
  metric    String
  value     Int
  period    String
  createdAt DateTime @default(now())

  @@unique([tenantId, metric, period])
  @@map("mm_usage")
}
