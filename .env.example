# ============================================================
# MentorMatch - Environment Variables
# ============================================================
# Copie este arquivo para .env.local e preencha os valores
# NUNCA commite o arquivo .env.local
# No deploy na Vercel, configure em Settings > Environment Variables
# ============================================================

# --------------------------------------------------
# Next.js
# --------------------------------------------------
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-here-min-32-chars

# --------------------------------------------------
# Database (Vercel Postgres)
# Obtenha em: Vercel Dashboard > Storage > Postgres > .env.local
# --------------------------------------------------
DATABASE_URL="postgres://default:password@host:5432/verceldb?pgbouncer=true&connect_timeout=15"
POSTGRES_PRISMA_URL="postgres://default:password@host:5432/verceldb?pgbouncer=true&connect_timeout=15"
POSTGRES_URL_NON_POOLING="postgres://default:password@host:5432/verceldb"

# --------------------------------------------------
# Authentication (NextAuth.js)
# --------------------------------------------------
AUTH_SECRET=your-secret-key-here-min-32-chars
AUTH_URL=http://localhost:3000
EMAIL_FROM=noreply@seu-dominio.com

# --------------------------------------------------
# Email (Resend)
# Obtenha em: https://resend.com > API Keys
# --------------------------------------------------
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --------------------------------------------------
# File Storage (Vercel Blob)
# Obtenha em: Vercel Dashboard > Storage > Blob > .env.local
# --------------------------------------------------
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxxxxxx

# --------------------------------------------------
# App Configuration
# --------------------------------------------------
NODE_ENV=development
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --------------------------------------------------
# Super Admin (credenciais do primeiro admin)
# --------------------------------------------------
SUPER_ADMIN_EMAIL=admin@seu-dominio.com
SUPER_ADMIN_PASSWORD=senha-segura-aqui

# --------------------------------------------------
# Feature Flags
# --------------------------------------------------
ENABLE_MAGIC_LINK=true
ENABLE_PUBLIC_REGISTRATION=true
ENABLE_BILLING=false
ENABLE_PUSH_NOTIFICATIONS=false

# --------------------------------------------------
# PWA / Push Notifications (opcional - futuro)
# --------------------------------------------------
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
# VAPID_PRIVATE_KEY=your-vapid-private-key

# --------------------------------------------------
# Stripe / Billing (futuro - nao configurar no MVP)
# --------------------------------------------------
# STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxx
